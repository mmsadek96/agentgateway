# Generate your own RSA keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the contents here (replace newlines with \n)

STATION_PRIVATE_KEY="REPLACE_WITH_YOUR_RSA_PRIVATE_KEY"
STATION_PUBLIC_KEY="REPLACE_WITH_YOUR_RSA_PUBLIC_KEY"
CERTIFICATE_EXPIRY_SECONDS=300
PORT=3456

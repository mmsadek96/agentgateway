# Shopify App credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_draft_orders,read_orders

# Application host (without protocol)
HOST=your-app.herokuapp.com

# AgentTrust Station configuration
AGENTTRUST_STATION_URL=https://station.agenttrust.dev
AGENTTRUST_API_KEY=your_agenttrust_api_key

# Server port
PORT=3000

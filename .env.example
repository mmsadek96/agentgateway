# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/agenttrust?schema=public"

# Server port
PORT=3000

# RSA key pair for signing JWT certificates
# Generate with: npm run generate-keys
STATION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
STATION_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# Certificate expiry in seconds (default: 300 = 5 minutes)
CERTIFICATE_EXPIRY_SECONDS=300

# Base L2 blockchain integration (optional — system works without it)
# Private key of the deployer wallet for on-chain writes
# BASE_PRIVATE_KEY=0xyour_private_key_here
